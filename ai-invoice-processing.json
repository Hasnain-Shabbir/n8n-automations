    {
      "parameters": {
        "jsCode": "const response  = $input.first().json;\nconst raw       = response.output[0].content[0].text;\nconst emailData = $('Store Email Data').first().json;\n\nlet invoice;\ntry {\n  const cleaned = raw.replace(/```json|```/g, '').trim();\n  invoice = JSON.parse(cleaned);\n} catch(e) {\n  invoice = {\n    vendor_name:    'PARSE ERROR',\n    invoice_number: 'UNKNOWN',\n    total_amount:   0,\n    currency:       'USD',\n    parse_error:    e.message\n  };\n}\n\n// Validate required fields\nconst missing = [];\nif (!invoice.vendor_name)    missing.push('vendor_name');\nif (!invoice.invoice_number) missing.push('invoice_number');\nif (!invoice.total_amount)   missing.push('total_amount');\nif (!invoice.invoice_date)   missing.push('invoice_date');\n\nconst status = missing.length === 0 \n  ? 'Complete' \n  : 'Needs Review — Missing: ' + missing.join(', ');\n\n// Format line items as readable string for Google Sheets\nconst lineItemsStr = (invoice.line_items || []).map(item =>\n  item.description + ' x' + item.quantity + ' @ ' + item.unit_price + ' = ' + item.amount\n).join(' | ');\n\nreturn [{\n  json: {\n    // Invoice fields\n    vendor_name:     invoice.vendor_name     || '',\n    vendor_email:    invoice.vendor_email    || '',\n    vendor_address:  invoice.vendor_address  || '',\n    invoice_number:  invoice.invoice_number  || '',\n    invoice_date:    invoice.invoice_date    || '',\n    due_date:        invoice.due_date        || '',\n    subtotal:        invoice.subtotal        || 0,\n    tax_amount:      invoice.tax_amount      || 0,\n    tax_rate:        invoice.tax_rate        || '',\n    total_amount:    invoice.total_amount    || 0,\n    currency:        invoice.currency        || 'USD',\n    payment_terms:   invoice.payment_terms   || '',\n    notes:           invoice.notes           || '',\n    line_items:      lineItemsStr,\n    // Email metadata from Store Email Data node\n    email_subject:   emailData.email_subject || '',\n    email_from:      emailData.email_from    || '',\n    email_date:      emailData.email_date    || '',\n    email_id:        emailData.email_id      || '',\n    // Processing metadata\n    status:          status,\n    missing_fields:  missing.join(', '),\n    needs_review:    missing.length > 0,\n    processed_at:    new Date().toISOString(),\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        464,
        -400
      ],
      "id": "74a18434-d1c4-4cde-a309-016cd0f24e03",
      "name": "Parse Invoice Data"
    },
    {
      "parameters": {
        "jsCode": "const email  = $input.first().json;\nconst binary = $input.first().binary;\n\n// Find the PDF in binary data\n// Gmail node stores attachments as attachment_0, attachment_1 etc\nlet pdfBinary = null;\nlet pdfName   = 'invoice.pdf';\n\n// Loop through all binary keys to find the PDF\nfor (const key of Object.keys(binary || {})) {\n  const file = binary[key];\n  if (\n    file.mimeType === 'application/pdf' ||\n    file.fileExtension === 'pdf' ||\n    (file.fileName || '').toLowerCase().endsWith('.pdf')\n  ) {\n    pdfBinary = file;\n    pdfName   = file.fileName || file.filename || key + '.pdf';\n    break;\n  }\n}\n\nif (!pdfBinary) {\n  // Log what we have for debugging\n  throw new Error('No PDF found. Binary keys available: ' + Object.keys(binary || {}).join(', '));\n}\n\nreturn [{\n  json: {\n    email_subject:  email.subject                       || '',\n    email_from:     email.from?.value?.[0]?.address    || '',\n    email_date:     email.date                          || new Date().toISOString(),\n    email_id:       email.id                            || '',\n    pdf_name:       pdfName,\n    pdf_mime:       pdfBinary.mimeType                  || 'application/pdf',\n    pdf_size:       pdfBinary.fileSize                  || 0,\n  },\n  binary: {\n    pdf_file: pdfBinary  // pass the binary PDF forward\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
