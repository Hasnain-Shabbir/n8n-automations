    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst systemPrompt = [\n  'You are an invoice data extraction expert.',\n  'Extract all information from this invoice PDF.',\n  'Respond with valid JSON only. No markdown. No extra text.',\n  '',\n  'Extract these exact fields:',\n  '- vendor_name: company that issued the invoice',\n  '- vendor_email: vendor email if present',\n  '- vendor_address: vendor address if present',\n  '- invoice_number: unique invoice ID',\n  '- invoice_date: date invoice was issued (YYYY-MM-DD)',\n  '- due_date: payment due date (YYYY-MM-DD)',\n  '- line_items: array of {description, quantity, unit_price, amount}',\n  '- subtotal: amount before tax (number)',\n  '- tax_amount: tax amount (number)',\n  '- tax_rate: tax percentage if shown',\n  '- total_amount: final total (number)',\n  '- currency: USD/GBP/EUR etc',\n  '- payment_terms: e.g. Net 30',\n  '- notes: any additional notes on invoice',\n  '',\n  'If a field is not found use null.',\n  'For dates always use YYYY-MM-DD format.',\n  'For amounts always use numbers not strings.',\n  '',\n  'Return ONLY this JSON structure:',\n  '{\"vendor_name\":\"...\", \"vendor_email\":null, \"vendor_address\":\"...\",',\n  '\"invoice_number\":\"...\", \"invoice_date\":\"2024-01-15\", \"due_date\":\"2024-02-15\",',\n  '\"line_items\":[{\"description\":\"...\", \"quantity\":1, \"unit_price\":100, \"amount\":100}],',\n  '\"subtotal\":100, \"tax_amount\":10, \"tax_rate\":\"10%\", \"total_amount\":110,',\n  '\"currency\":\"USD\", \"payment_terms\":\"Net 30\", \"notes\":null}'\n].join('\\n');\n\nreturn [{\n  json: {\n    system_prompt: systemPrompt,\n    pdf_content:   input.pdf_content,\n    pdf_name:      input.pdf_name,\n    email_subject: input.email_subject,\n    email_from:    input.email_from,\n    email_date:    input.email_date,\n    email_id:      input.email_id,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
